          <!-- Card 7 -->
          <div class="shrink-0 w-full lg:w-1/3 px-3 flex">
            <div class="bg-white rounded-2xl p-6 shadow-md border border-slate-100 hover:shadow-xl hover:border-gold/30 transition-all duration-300 flex flex-col w-full min-h-[280px]">
              <div class="flex items-center gap-1 mb-3 text-gold text-sm">★★★★★</div>
