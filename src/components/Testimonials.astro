---
// Testimonials.astro - Carrusel infinito de testimonios del Diplomado Internacional en Interiorismo
// Copiado directamente del proyecto LANDING INTERIORISMO
---

<section class="py-10 md:py-20 bg-slate-50 overflow-hidden">
  <div class="container mx-auto px-4 max-w-6xl">

    <!-- Section Header -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 bg-navy text-white px-5 py-2 rounded-full mb-6 shadow-lg">
        <span class="text-gold text-base">★★★★★</span>
        <span class="text-xs font-bold uppercase tracking-widest">Opiniones Reales de Nuestros Egresados</span>
      </div>
      <h2 class="text-3xl md:text-5xl font-serif font-bold text-navy mb-4 leading-tight">
        Lo que dicen quienes ya <span class="italic text-gold">transformaron</span> su carrera
      </h2>
      <p class="text-slate-500 text-base md:text-lg max-w-2xl mx-auto">
        Más de 2,400 diseñadores certificados en Colombia y Latinoamérica avalan la calidad del Diplomado Internacional en Interiorismo de Instituto Osbord.
      </p>
    </div>

    <!-- Carousel Container -->
    <div
      x-data="{
        current: 0,
        total: 8,
        visibleCards: 3,
        transitioning: true,
        autoplayInterval: null,
        
        // Touch & Drag state
        startX: 0,
        currentX: 0,
        isDown: false,
        
        touchStart(e) {
          this.startX = e.touches ? e.touches[0].clientX : e.clientX;
          this.currentX = this.startX;
          this.isDown = true;
          clearInterval(this.autoplayInterval);
        },
        touchMove(e) {
          if (!this.isDown) return;
          this.currentX = e.touches ? e.touches[0].clientX : e.clientX;
        },
        touchEnd() {
          if (!this.isDown) return;
          this.isDown = false;
          const diff = this.startX - this.currentX;
          // Threshold of 50px to trigger slide change
          if (Math.abs(diff) > 50) {
            if (diff > 0) {
              this.next();
            } else {
              this.prev();
            }
          }
          this.restartAutoplay();
        },
        updateVisible() {
          this.visibleCards = window.innerWidth >= 1024 ? 3 : 1;
        },
        next() {
          if (this.current >= this.total) return;
          this.current++;
          this.checkBoundary();
        },
        prev() {
          if (this.current <= 0) {
            // Desactiva transición y salta al clon del final
            this.transitioning = false;
            this.current = this.total;
            // Espera un frame y retrocede con transición
            setTimeout(() => {
              this.transitioning = true;
              this.current--;
            }, 30);
          } else {
            this.current--;
          }
        },
        checkBoundary() {
          if (this.current >= this.total) {
            setTimeout(() => {
              this.transitioning = false;
              this.current = 0;
              setTimeout(() => {
                this.transitioning = true;
              }, 30);
            }, 500); // Coincide con la duración de la transición (500ms)
          }
        },
        goTo(i) {
          this.current = i;
          this.restartAutoplay();
        },
        startAutoplay() {
          this.autoplayInterval = setInterval(() => this.next(), 5000);
        },
        restartAutoplay() {
          clearInterval(this.autoplayInterval);
          this.startAutoplay();
        },
        init() {
          this.updateVisible();
          this.startAutoplay();
        }
      }"
      @resize.window="updateVisible()"
      class="relative select-none"
    >
      <!-- Carousel Track Window -->
      <div 
        class="relative overflow-hidden w-full px-1 py-4 cursor-grab active:cursor-grabbing"
        @touchstart="touchStart($event)"
        @touchmove="touchMove($event)"
        @touchend="touchEnd()"
        @mousedown="touchStart($event)"
        @mousemove="touchMove($event)"
        @mouseup="touchEnd()"
        @mouseleave="isDown = false"
      >
        <!-- Flex Track -->
        <div
          :class="transitioning ? 'transition-transform duration-500 ease-out' : ''"
          class="flex -mx-3"
          :style="`transform: translateX(-${current * (100 / visibleCards)}%)`"
        >
          <!-- Card 1 -->
          <div class="shrink-0 w-full lg:w-1/3 px-3 flex">
            <div class="bg-white rounded-2xl p-6 shadow-md border border-slate-100 hover:shadow-xl hover:border-gold/30 transition-all duration-300 flex flex-col w-full min-h-[280px]">
              <div class="flex items-center gap-1 mb-3 text-gold text-sm">★★★★★</div>
              <blockquote class="text-slate-600 text-xs md:text-sm leading-relaxed mb-5 flex-grow">
                "Este diplomado internacional cambió completamente mi perspectiva. En apenas dos meses ya tenía clientes reales y estaba diseñando espacios en 3D que parecían de revista. El aval americano me abrió puertas que yo nunca imaginé."
              </blockquote>
              <div class="flex items-center gap-3 border-t border-slate-100 pt-4 mt-auto">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-gold to-amber-600 flex items-center justify-center text-white font-bold text-sm shrink-0">V</div>
                <div>
                  <p class="font-bold text-navy text-xs md:text-sm leading-none mb-0.5">Valentina Rodríguez</p>
                  <p class="text-[10px] text-slate-400">Diseñadora de Interiores · Miami, EE.UU.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Card 2 -->
          <div class="shrink-0 w-full lg:w-1/3 px-3 flex">
            <div class="bg-white rounded-2xl p-6 shadow-md border border-slate-100 hover:shadow-xl hover:border-gold/30 transition-all duration-300 flex flex-col w-full min-h-[280px]">
              <div class="flex items-center gap-1 mb-3 text-gold text-sm">★★★★★</div>
              <blockquote class="text-slate-600 text-xs md:text-sm leading-relaxed mb-5 flex-grow">
                "No creía que podía aprender interiorismo 3D tan rápido. Los tutores te acompañan en todo momento y los módulos son muy claros. Hoy trabajo como freelancer y ya recuperé la inversión con mi primer proyecto."
              </blockquote>
              <div class="flex items-center gap-3 border-t border-slate-100 pt-4 mt-auto">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center text-white font-bold text-sm shrink-0">C</div>
                <div>
                  <p class="font-bold text-navy text-xs md:text-sm leading-none mb-0.5">Carlos Medina</p>
