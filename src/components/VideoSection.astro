---
import { ArrowDown } from '@lucide/astro';
---

<section class="pt-10 pb-6 bg-navy text-white relative">
  <div class="container mx-auto px-4 max-w-5xl">
    <!-- Sales Pitch Video Container -->
    <div 
      x-data="{ 
        playing: false, 
        playVideo() { 
          const v = this.$refs.video; 
          if(v.paused) { 
            v.play(); 
            this.playing = true; 
          } else { 
            v.pause(); 
            this.playing = false; 
          } 
        } 
      }"
      class="relative w-full max-w-[900px] mx-auto rounded-2xl overflow-hidden shadow-2xl shadow-black/40 group/player"
    >
      <!-- HTML5 Video Player -->
      <video 
        id="pitch-video"
        x-ref="video"
        @play="playing = true"
        @pause="playing = false"
        class="w-full h-auto block" 
        controls="controls" 
        controlslist="nodownload" 
        oncontextmenu="return false;"
        preload="metadata"
        playsinline
      >
        <source src="https://pub-43479c11d9824c46912d0434d59e3b39.r2.dev/VSL%20%E2%80%94%20Ma%CC%81ster%20en%20Interiorismo%2C%20Disen%CC%83o%20y%20Decoracio%CC%81n%20de%20Interiores%203D%20-%20Instituto%20Osbord_pdf_1080p.mp4#t=0.001" type="video/mp4">
        Tu navegador no soporta la reproducción de videos.
      </video>

      <!-- Centered Play Button Overlay -->
      <div 
        x-show="!playing"
        @click="playVideo()"
        class="absolute inset-0 flex items-center justify-center bg-black/25 cursor-pointer transition-all duration-300 hover:bg-black/35 z-10"
      >
        <button class="w-16 h-16 md:w-22 md:h-22 bg-gold hover:bg-gold-dark text-navy rounded-full flex items-center justify-center shadow-2xl transform transition-transform duration-300 group-hover/player:scale-110 active:scale-95">
          <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-8 h-8 md:w-11 md:h-11 ml-1 text-navy">
            <path d="M8 5v14l11-7z" />
          </svg>
        </button>
      </div>
    </div>

    <script>
      const video = document.getElementById('pitch-video') as HTMLVideoElement | null;
      if (video) {
        // Set default playback rate
        video.defaultPlaybackRate = 1;
        video.playbackRate = 1;
        
        // Ensure playback rate persists when playing
        video.addEventListener('play', () => {
          video.playbackRate = 1;
        });
      }
    </script>

    <!-- Scroll to Pricing CTA Button -->
    <div class="mt-10 text-center">
      <button 
        onclick="document.getElementById('oferta').scrollIntoView({ behavior: 'smooth' })"
        class="group relative inline-flex items-center gap-2 bg-gradient-to-r from-gold to-gold-dark text-navy font-bold text-xs md:text-base px-4 py-2.5 md:px-8 md:py-4 rounded-xl shadow-xl shadow-gold/20 hover:shadow-2xl hover:shadow-gold/45 transition-all duration-300 transform hover:scale-[1.03] active:scale-[0.97]"
      >
        <span class="uppercase tracking-wide">Ver Planes y Ofertas Especiales</span>
        <ArrowDown class="w-3.5 h-3.5 md:w-4.5 md:h-4.5 group-hover:translate-y-1 transition-transform" />
        
        <!-- Subtle pulsing border effect -->
        <span class="absolute -inset-[2px] md:-inset-[3px] border border-gold/40 rounded-xl animate-pulse -z-10 group-hover:border-gold/60 transition-colors"></span>
      </button>
    </div>
  </div>
</section>
