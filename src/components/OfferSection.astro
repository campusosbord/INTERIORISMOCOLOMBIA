---
import { ShieldCheck } from '@lucide/astro';
import { getCOPRate } from '../utils/tasa';

// ── Precios base en USD (fuente de verdad) ───────────────────────────────────
const PRICES_USD = {
  full:     147,  // Pago único
  finance1:  79,  // 1ra cuota de 2
  finance2:  55,  // 1ra cuota de 3
};

// ── Tipo de cambio USD -> COP ─────────────────────────────────────────────────
const exchangeRate = await getCOPRate();

// ── Precios COP exactos (sin redondeo, idénticos al Checkout) ────────────────
const copFull     = Math.floor(PRICES_USD.full     * exchangeRate);
const copFinance1 = Math.floor(PRICES_USD.finance1 * exchangeRate);
const copFinance2 = Math.floor(PRICES_USD.finance2 * exchangeRate);

const fCOP = (v: number) => new Intl.NumberFormat('es-CO', {
  style: 'currency', currency: 'COP', minimumFractionDigits: 0, maximumFractionDigits: 0
}).format(v);
const fUSD = (v: number) => new Intl.NumberFormat('en-US', {
  style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0
}).format(v);
---

<section id="oferta" class="relative py-20 bg-navy text-white overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute top-0 left-0 w-96 h-96 bg-gold/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-gold/5 rounded-full blur-3xl translate-x-1/2 translate-y-1/2 pointer-events-none"></div>

  <div class="container mx-auto px-4 max-w-4xl relative z-10">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-5xl font-serif font-bold text-white mb-4">
        Comienza Tu Formación Hoy
      </h2>
      <p class="text-slate-300 max-w-xl mx-auto text-sm md:text-base">
        Elige la opción que mejor se adapte a ti. Todos los planes incluyen acceso inmediato a la plataforma y a todos los bonos.
      </p>
      <!-- Tasa de cambio live -->
      <div class="inline-flex items-center gap-2 mt-4 bg-white/5 border border-white/10 rounded-full px-4 py-1.5 text-xs text-slate-400">
        <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse inline-block"></span>
        Precios en <strong class="text-white mx-1">USD</strong> · Ref. Tasa Oficial Colombia: 
        <span class="font-mono text-gold">1 USD = {exchangeRate.toLocaleString('es-CO')} COP</span>
      </div>
    </div>

    <!-- Pricing Box -->
    <div
      class="bg-navy-light/40 backdrop-blur rounded-3xl p-6 md:p-10 shadow-2xl border border-white/10 max-w-2xl mx-auto relative overflow-hidden"
    >
      <div class="absolute top-0 right-0 bg-green-600 text-white text-xs font-bold px-4 py-1.5 rounded-bl-xl uppercase tracking-wider">
        50% de descuento
      </div>

      <div class="text-center space-y-6">
        <h3 class="text-gold font-bold uppercase tracking-widest text-sm md:text-base border-b border-white/10 pb-3 mb-4">
          Oferta Cierre de Grupo
        </h3>

        <div class="space-y-4 font-sans text-left">
          <!-- Option 1: Full Payment -->
          <div class="bg-white/5 p-6 rounded-2xl border border-white/10 hover:border-gold/30 transition-all duration-350 relative overflow-hidden flex flex-col sm:flex-row justify-between items-center gap-4 text-center sm:text-left">
             <div>
               <p class="text-[10px] text-gold font-bold uppercase tracking-wider mb-1">Inscripción Regular (Único Pago)</p>
               <h4 class="text-xl font-bold font-serif text-white">Pago Único Completo</h4>
               <p class="text-xs text-slate-400 mt-1">Acceso de por vida a todo el material.</p>
             </div>
             <div class="flex flex-col items-center sm:items-end shrink-0">
               <div class="flex items-baseline gap-1">
                 <span class="text-4xl font-bold text-white font-serif">{fUSD(PRICES_USD.full)}</span>
                 <span class="text-sm font-semibold text-slate-400">USD</span>
               </div>
               <!-- Resaltado prominente estilo pill como la imagen de referencia -->
               <div class="mt-2 bg-emerald-500/15 border border-emerald-400/40 rounded-full px-3.5 py-1 text-center">
                 <p class="text-xs font-bold text-emerald-300">
                   ≈ {fCOP(copFull)} COP
                 </p>
               </div>
             </div>
          </div>

          <!-- Financing Options -->
          <div class="bg-white/5 p-5 rounded-2xl border border-white/10">
            <p class="text-[10px] text-center text-slate-400 font-bold uppercase tracking-widest mb-4 border-b border-white/5 pb-2">Financiamiento Especial</p>
            
            <div class="grid sm:grid-cols-2 gap-4">
              <!-- Option A -->
              <div class="text-center p-5 bg-navy/60 rounded-xl border border-white/5 shadow-inner hover:border-gold/20 transition-all duration-350 flex flex-col items-center justify-between">
                <div>
                  <p class="text-[10px] text-gold uppercase font-bold mb-1">Opción A (2 Cuotas)</p>
                  <div class="flex items-baseline justify-center gap-1 my-1">
                    <span class="text-3xl font-bold text-white font-serif">{fUSD(PRICES_USD.finance1)}</span>
                    <span class="text-xs font-semibold text-slate-400">USD</span>
                  </div>
                  <p class="text-[10px] text-slate-400 leading-tight">Cuota Inicial</p>
                </div>
                <!-- Resaltado estilo pill -->
                <div class="mt-3 bg-emerald-500/15 border border-emerald-400/30 rounded-full px-3 py-1 w-full max-w-[170px]">
                  <p class="text-[11px] font-bold text-emerald-300">
                    ≈ {fCOP(copFinance1)} COP
                  </p>
                </div>
              </div>
              
              <!-- Option B -->
              <div class="text-center p-5 bg-navy/60 rounded-xl border border-white/5 shadow-inner hover:border-gold/20 transition-all duration-350 flex flex-col items-center justify-between">
                <div>
                  <p class="text-[10px] text-gold uppercase font-bold mb-1">Opción B (3 Cuotas)</p>
                  <div class="flex items-baseline justify-center gap-1 my-1">
                    <span class="text-3xl font-bold text-white font-serif">{fUSD(PRICES_USD.finance2)}</span>
                    <span class="text-xs font-semibold text-slate-400">USD</span>
                  </div>
                  <p class="text-[10px] text-slate-400 leading-tight">Cuota Inicial</p>
                </div>
                <!-- Resaltado estilo pill -->
                <div class="mt-3 bg-emerald-500/15 border border-emerald-400/30 rounded-full px-3 py-1 w-full max-w-[170px]">
                  <p class="text-[11px] font-bold text-emerald-300">
                    ≈ {fCOP(copFinance2)} COP
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Evergreen Countdown -->
        <div 
          x-data="countdownTimer()"
          x-init="initTimer()"
          class="bg-navy rounded-2xl p-5 mt-6 shadow-inner border border-white/5"
        >
          <p class="text-[10px] text-center mb-3 text-slate-400 uppercase tracking-widest">Inscripciones abiertas hasta:</p>
          <div class="flex justify-center gap-4 text-center font-mono">
             <div>
               <span class="text-3xl font-bold text-gold" x-text="format(hours)">47</span>
               <p class="text-[9px] uppercase text-slate-400 mt-1">Horas</p>
             </div>
             <span class="text-2xl text-slate-600">:</span>
             <div>
               <span class="text-3xl font-bold text-gold" x-text="format(minutes)">59</span>
               <p class="text-[9px] uppercase text-slate-400 mt-1">Min</p>
             </div>
             <span class="text-2xl text-slate-600">:</span>
             <div>
               <span class="text-3xl font-bold text-gold" x-text="format(seconds)">59</span>
               <p class="text-[9px] uppercase text-slate-400 mt-1">Seg</p>
             </div>
          </div>
        </div>

        <a href="/checkout" onclick="trackInitiateCheckout()" class="block w-full bg-emerald-500 hover:bg-emerald-600 text-white font-bold text-lg py-4 rounded-xl shadow-lg hover:shadow-emerald-500/30 transition-all mt-6 uppercase tracking-tight transform hover:scale-[1.02] active:scale-[0.98]">
          ¡Inscribirme Ahora!
        </a>

        <!-- Garantía de 7 días -->
        <div class="mt-4 flex items-start gap-3 bg-white/5 border border-emerald-400/20 rounded-xl p-4 text-left">
          <span class="text-2xl shrink-0">🛡️</span>
          <div>
            <p class="text-xs font-bold text-emerald-300 uppercase tracking-wider mb-0.5">Garantía de 7 días sin preguntas</p>
            <p class="text-[11px] text-slate-300 leading-relaxed">
              Si en los primeros 7 días sientes que este diplomado no es para ti, te devolvemos el 100% de tu dinero. Sin formularios, sin justificaciones, sin preguntas. Solo escríbenos y listo.
            </p>
          </div>
        </div>

        <!-- Payment Methods -->
        <div class="mt-6 pt-6 border-t border-white/10">
          <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mb-3">Paga seguro con:</p>
          <div class="flex flex-col items-center gap-2 opacity-80 hover:opacity-100 transition-all duration-500">
            <span class="text-lg font-bold text-white tracking-wide">Stripe</span>
            <div class="flex flex-wrap justify-center gap-x-2 gap-y-1 text-slate-400 text-[10px] font-medium text-center max-w-md">
              <span>💳 Tarjetas</span>
              <span>•</span>
              <span>📱 Apple Pay</span>
              <span>•</span>
              <span>🔗 Link</span>
              <span>•</span>
              <span>🛒 Amazon Pay</span>
              <span>•</span>
              <span>💸 Cash App Pay</span>
              <span>•</span>
              <span>🏦 Transferencia Bancaria</span>
            </div>
          </div>
        </div>
        
        <p class="text-xs text-center text-slate-400 mt-4 flex items-center justify-center gap-1.5">
          <ShieldCheck class="w-4.5 h-4.5 text-emerald-500" />
          <span>Acceso inmediato al Campus Online. Pago 100% Seguro.</span>
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  // Alpine.js component definition (global scope for simplicity in Astro)
  document.addEventListener('alpine:init', () => {
    // Check if the timer is already registered to avoid duplication errors on hot reload
    if (!Alpine.store('countdownTimerRegistered')) {
      Alpine.data('countdownTimer', () => ({
        hours: 48,
        minutes: 0,
        seconds: 0,
        totalSeconds: 48 * 3600,
        
        initTimer() {
          let storedTime = null;
          try {
            storedTime = localStorage.getItem('osbord_interiorismo_colombia_timer');
          } catch(e) { /* private browsing or blocked */ }

          const now = new Date().getTime();
          
          if (storedTime) {
            try {
              const parsed = JSON.parse(storedTime);
              const expiry = parsed && parsed.expiry;
              if (expiry && typeof expiry === 'number' && expiry > now) {
                this.totalSeconds = Math.floor((expiry - now) / 1000);
              } else {
                this.resetTimer();
              }
            } catch(e) {
              this.resetTimer();
            }
          } else {
            this.resetTimer();
          }

          this.updateDisplay();
          
          setInterval(() => {
            if (this.totalSeconds > 0) {
              this.totalSeconds--;
              this.updateDisplay();
            } else {
              this.resetTimer(); // Loop for evergreen effect
            }
          }, 1000);
        },

        resetTimer() {
          const now = new Date().getTime();
          const expiry = now + (48 * 3600 * 1000);
          try {
            localStorage.setItem('osbord_interiorismo_colombia_timer', JSON.stringify({ expiry }));
          } catch(e) { /* private browsing or blocked */ }
          this.totalSeconds = 48 * 3600;
        },

        updateDisplay() {
          this.hours = Math.floor(this.totalSeconds / 3600);
          this.minutes = Math.floor((this.totalSeconds % 3600) / 60);
          this.seconds = this.totalSeconds % 60;
        },
        
        format(val) {
          return val.toString().padStart(2, '0');
        }
      }));
      Alpine.store('countdownTimerRegistered', true);
    }
  });
</script>
