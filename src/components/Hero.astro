---
import { BadgeCheck, Briefcase, GraduationCap, Timer, Clock } from '@lucide/astro';
---

<section class="relative min-h-[60vh] flex items-center justify-center pt-22 pb-8 overflow-hidden">
  <!-- Dynamic Background with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80" 
      alt="Diseño de interiores moderno y profesional" 
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-navy/80 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-navy via-transparent to-transparent"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10 max-w-4xl text-center">
    <!-- Centered Column: Copy -->
    <div class="text-white space-y-6 mx-auto mt-8 md:mt-0">
      <div class="flex flex-wrap gap-2 justify-center">
        <div class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur px-3 md:px-4 py-1 rounded-full border border-white/20 text-xs md:text-sm font-medium text-gold-light">
          <span class="animate-pulse text-[10px] md:text-xs">●</span> Cupos Limitados
        </div>
        <div class="inline-flex items-center gap-1.5 bg-yellow-500/20 backdrop-blur px-2.5 md:px-3 py-1 rounded-full border border-yellow-400/30 text-xs md:text-sm">
          <span class="text-xs md:text-base">🇨🇴</span>
          <span class="text-yellow-200 font-medium">Sede Colombia</span>
        </div>
        <div class="inline-flex items-center gap-1.5 bg-emerald-500/15 backdrop-blur px-3 md:px-4 py-1 rounded-full border border-emerald-500/20 text-xs md:text-sm">
          <span class="text-emerald-400 text-xs font-bold">✓</span>
          <span class="text-emerald-200 font-medium">+2,400 Egresados</span>
        </div>
      </div>
      
      <h1 class="text-2xl md:text-4xl lg:text-6xl font-bold font-serif leading-tight">
        Diplomado Internacional en Interiorismo, Diseño y Decoración de Interiores 3D
      </h1>
      
      <p class="text-lg md:text-2xl font-medium text-transparent bg-clip-text bg-gradient-to-r from-white via-slate-200 to-slate-400 max-w-2xl mx-auto drop-shadow-sm pb-1">
        Convierte tu Pasión en un <span class="text-gold italic font-bold">Negocio Rentable</span> con Aval Americano. Domina el arte de crear espacios y experiencias visuales únicas.
      </p>

      <!-- Trust Badges -->
      <div class="flex flex-col md:flex-row gap-4 pt-4 justify-center">
        <div class="flex items-center gap-3 bg-navy-light/50 p-3 rounded-lg border border-white/10">
          <BadgeCheck class="text-blue-400 w-6 h-6 shrink-0" />
          <div class="text-left">
            <p class="text-[10px] text-slate-400 uppercase tracking-wider">Aval</p>
            <p class="font-semibold text-[11px] md:text-sm">Internacional EE.UU 🇺🇸</p>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-navy-light/50 p-3 rounded-lg border border-white/10">
          <Briefcase class="text-emerald-400 w-6 h-6 shrink-0" />
          <div class="text-left">
            <p class="text-[10px] text-slate-400 uppercase tracking-wider">Bolsa de</p>
            <p class="font-semibold text-[11px] md:text-sm">Empleo Garantizada</p>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-navy-light/50 p-3 rounded-lg border border-white/10">
          <GraduationCap class="text-gold w-6 h-6 shrink-0" />
          <div class="text-left">
            <p class="text-[10px] text-slate-400 uppercase tracking-wider">Clases</p>
            <p class="font-semibold text-[11px] md:text-sm">100% Online + Tutores</p>
          </div>
        </div>
      </div>
      
      <!-- Duration & Flexibility Info -->
      <div class="flex flex-nowrap gap-2 md:gap-3 pt-2 justify-center overflow-visible">
        <div class="inline-flex items-center gap-1.5 md:gap-2 bg-emerald-500/20 backdrop-blur-sm px-3 py-1.5 md:px-4 md:py-2 rounded-full border border-emerald-400/30 flex-shrink-0">
          <Timer class="w-3.5 h-3.5 md:w-4 md:h-4 text-emerald-400" />
          <span class="text-[10px] md:text-sm font-semibold text-white">Duración: <span class="text-emerald-300">3 Meses</span></span>
        </div>
        <div class="inline-flex items-center gap-1.5 md:gap-2 bg-blue-500/20 backdrop-blur-sm px-3 py-1.5 md:px-4 md:py-2 rounded-full border border-blue-400/30 flex-shrink-0">
          <Clock class="w-3.5 h-3.5 md:w-4 md:h-4 text-blue-400" />
          <span class="text-[10px] md:text-sm font-semibold text-white">Horarios <span class="text-blue-300">Flexibles</span></span>
        </div>
      </div>
    </div>
  </div>
</section>
